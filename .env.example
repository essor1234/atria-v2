# LLM provider key (any one)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=
# FIREWORKS_API_KEY=

# Atria runtime
ATRIA_API_BASE_URL=https://your-llm-proxy.example.com/v1/chat/completions
ATRIA_MODEL=your-model-name

# Postgres (matches db service defaults)
DATABASE_URL=postgresql://atria:atria@db:5432/atria

# maintenance_copilot — LLM endpoint override for no-GPU hosts (else uses local vLLM).
# MC_SYNTHESIS_BASE_URL=https://proxy.onebot.meobeo.ai/v1
# MC_KG_EXTRACT_BASE_URL=https://proxy.onebot.meobeo.ai/v1
