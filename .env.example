# LLM provider key (any one)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=
# FIREWORKS_API_KEY=

# Atria runtime
# ATRIA_API_BASE_URL=https://your-llm-proxy.example.com/v1/chat/completions
ATRIA_MODEL=gpt-5.5
# Used automatically if a call with ATRIA_MODEL fails (rate limit, unavailable, etc.)
ATRIA_FALLBACK_MODEL=gpt-5.4

# Optional: relocate the app-data home (sessions, cache, workspaces, modules,
# snapshots, etc.). Defaults to ~/.atria under the user home if unset.
# ATRIA_DIR=D:\atria-home

# Postgres (matches db service defaults)
DATABASE_URL=postgresql://atria:atria@db:5432/atria
